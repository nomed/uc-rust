{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://uc-rust.local/schemas/runtime-profile-config.schema.json",
  "title": "UC Rust Runtime Profile Configuration",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "configuration_revision",
    "runtime_identity",
    "runtime_profile",
    "operation_set",
    "capability_bindings",
    "components"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "configuration_revision": { "type": "string", "minLength": 1 },
    "content_digest": { "type": "string", "minLength": 1 },
    "runtime_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["runtime_id", "tenant_id", "legal_entity_id"],
      "properties": {
        "runtime_id": { "type": "string", "minLength": 1 },
        "tenant_id": { "type": "string", "minLength": 1 },
        "legal_entity_id": { "type": "string", "minLength": 1 },
        "store_id": { "type": "string" },
        "country": { "type": "string", "minLength": 2, "maxLength": 2 }
      }
    },
    "runtime_profile": {
      "type": "string",
      "enum": ["central", "store-edge", "warehouse-edge", "test"]
    },
    "operation_set": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "capability_bindings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["operation_id", "realization_id", "policy_revision"],
        "properties": {
          "operation_id": { "type": "string", "minLength": 1 },
          "realization_id": { "type": "string", "minLength": 1 },
          "policy_revision": { "type": "string", "minLength": 1 },
          "mandatory": { "type": "boolean", "default": true }
        }
      }
    },
    "components": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["component_id", "criticality", "reload_class", "start_deadline_ms", "stop_deadline_ms"],
        "properties": {
          "component_id": { "type": "string", "minLength": 1 },
          "criticality": {
            "type": "string",
            "enum": ["mandatory", "profile_mandatory", "optional", "on_demand"]
          },
          "reload_class": {
            "type": "string",
            "enum": ["dynamic_safe", "drain_then_reload", "restart_required", "immutable_identity"]
          },
          "depends_on": {
            "type": "array",
            "uniqueItems": true,
            "items": { "type": "string", "minLength": 1 }
          },
          "affected_operations": {
            "type": "array",
            "uniqueItems": true,
            "items": { "type": "string", "minLength": 1 }
          },
          "start_deadline_ms": { "type": "integer", "minimum": 1 },
          "stop_deadline_ms": { "type": "integer", "minimum": 1 }
        }
      }
    },
    "offline_policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "manifest_revision": { "type": "string" },
        "maximum_manifest_age_seconds": { "type": "integer", "minimum": 0 }
      }
    },
    "emergency_override": {
      "type": "object",
      "additionalProperties": false,
      "required": ["owner", "reason", "expires_at"],
      "properties": {
        "owner": { "type": "string", "minLength": 1 },
        "reason": { "type": "string", "minLength": 1 },
        "expires_at": { "type": "string", "format": "date-time" }
      }
    }
  }
}
