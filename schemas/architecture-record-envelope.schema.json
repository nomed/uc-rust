{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://uc-rust.dev/schemas/architecture-record-envelope.schema.json",
  "title": "UC Rust 1.0 Architecture Record Envelope",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "type", "schema_version", "content_version", "title", "summary", "status", "owners", "created_at", "updated_at", "scope", "provenance", "relations", "review"],
  "properties": {
    "id": {"type": "string", "pattern": "^[a-z][a-z0-9-]*:(ADR|RFC|CR|RRR|QAR|ER|SR|IR|DR|RR)-[0-9]{4,}$"},
    "type": {"enum": ["ADR", "RFC", "CR", "RRR", "QAR", "ER", "SR", "IR", "DR", "RR"]},
    "schema_version": {"const": 1},
    "content_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "title": {"type": "string", "minLength": 3},
    "summary": {"type": "string", "minLength": 10},
    "status": {"enum": ["Draft", "Proposed", "Accepted", "Deprecated", "Superseded", "Rejected", "Withdrawn"]},
    "owners": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["role"], "properties": {"role": {"type": "string", "minLength": 2}, "person": {"type": "string"}}}},
    "created_at": {"type": "string", "format": "date"},
    "updated_at": {"type": "string", "format": "date"},
    "scope": {"type": "string", "minLength": 5},
    "non_goals": {"type": "array", "items": {"type": "string"}},
    "provenance": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/provenance"}},
    "relations": {"type": "array", "items": {"$ref": "#/$defs/relation"}},
    "review": {"$ref": "#/$defs/review"},
    "evidence": {"type": "array", "items": {"$ref": "#/$defs/evidence"}},
    "deprecation": {"type": "object"},
    "superseded_by": {"type": "array", "items": {"type": "string"}},
    "waivers": {"type": "array", "items": {"$ref": "#/$defs/waiver"}}
  },
  "$defs": {
    "provenance": {"type": "object", "additionalProperties": false, "required": ["kind", "locator"], "properties": {"kind": {"enum": ["issue", "session", "uc-bok", "external-standard", "incident", "experiment", "migration"]}, "locator": {"type": "string", "minLength": 3}}},
    "relation": {"type": "object", "additionalProperties": false, "required": ["type", "target"], "properties": {"type": {"enum": ["references", "realizes_concept", "depends_on", "constrains", "implements", "exposes", "uses_data", "satisfies", "governed_by", "included_in", "supersedes", "deprecates", "conflicts_with", "waives"]}, "target": {"type": "string", "pattern": "^[a-z][a-z0-9-]*:[A-Za-z0-9][A-Za-z0-9._-]*$"}, "scope": {"type": "string"}, "valid_from": {"type": "string", "format": "date"}, "valid_until": {"type": "string", "format": "date"}, "provenance": {"$ref": "#/$defs/provenance"}, "inferred": {"const": false}}},
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required_roles", "reviewers", "disposition"],
      "properties": {
        "required_roles": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "reviewers": {"type": "array", "items": {"type": "string"}},
        "disposition": {"enum": ["pending", "accepted", "rejected", "withdrawn"]},
        "review_class": {"enum": ["continuous", "release", "periodic", "stable"]},
        "reviewed_at": {"type": "string", "format": "date"},
        "next_review_at": {"type": "string", "format": "date"},
        "review_interval_days": {"type": "integer", "minimum": 1},
        "event_triggers": {"type": "array", "uniqueItems": true, "items": {"enum": ["incident", "security_finding", "privacy_finding", "fiscal_or_legal_change", "external_standard_change", "public_contract_break", "quality_budget_failure", "economic_threshold_breach", "dependency_or_provider_change", "runtime_profile_change", "release_gate", "ownership_loss", "manual_request"]}},
        "overdue_grace_days": {"type": "integer", "minimum": 0},
        "escalation": {"type": "string", "minLength": 2},
        "unresolved_objections": {"type": "array", "items": {"type": "string"}}
      }
    },
    "evidence": {"type": "object", "additionalProperties": false, "required": ["kind", "locator", "claim", "produced_at"], "properties": {"kind": {"enum": ["code", "test", "benchmark", "trace", "report", "deployment", "operational-observation", "audit", "review"]}, "locator": {"type": "string"}, "digest": {"type": "string"}, "claim": {"type": "string"}, "produced_at": {"type": "string", "format": "date"}, "expires_at": {"type": "string", "format": "date"}, "result": {"type": "string"}}},
    "waiver": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "record", "scope", "deviation", "rationale", "owner", "approver", "residual_risk", "compensating_controls", "created_at", "expires_at", "remediation_issue", "disposition"],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z][a-z0-9-]*:WAIVER-[0-9]{4,}$"},
        "record": {"type": "string"},
        "scope": {"type": "string", "minLength": 3},
        "deviation": {"type": "string", "minLength": 3},
        "rationale": {"type": "string", "minLength": 3},
        "owner": {"type": "string", "minLength": 2},
        "approver": {"type": "string", "minLength": 2},
        "residual_risk": {"type": "string", "minLength": 3},
        "compensating_controls": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "created_at": {"type": "string", "format": "date"},
        "expires_at": {"type": "string", "format": "date"},
        "remediation_issue": {"type": "string", "minLength": 2},
        "evidence": {"type": "array", "items": {"$ref": "#/$defs/evidence"}},
        "disposition": {"enum": ["active", "expired", "revoked", "remediated"]}
      }
    }
  },
  "allOf": [
    {"if": {"properties": {"status": {"const": "Superseded"}}}, "then": {"required": ["superseded_by"]}},
    {"if": {"properties": {"status": {"const": "Deprecated"}}}, "then": {"required": ["deprecation"]}},
    {"if": {"properties": {"status": {"enum": ["Accepted", "Deprecated"]}}}, "then": {"properties": {"review": {"required": ["review_class", "reviewed_at"]}}}}
  ]
}